{% comment %}
  MAIN COLLECTION — Catálogo estilo Amazon
  - Sidebar con filtros (categorías, precio, marca, valoración)
  - Header con ordenación y toggle grid/lista
  - Grid de productos reales desde Shopify
  - Fallback: 12 productos de demostración cuando la colección está vacía
{% endcomment %}

{% paginate collection.products by section.settings.products_per_page %}

<div class="breadcrumb">
  <a href="{{ routes.root_url }}">Inicio</a><span>›</span>
  <span class="current">{{ collection.title | default: 'Catálogo' }}</span>
</div>

<!-- PAGE HEADER -->
<div class="page-header">
  <div class="ph-left">
    <h1>{{ collection.title | default: '🛒 Catálogo' }}</h1>
    <p>
      {% if collection.products_count > 0 %}
        {{ collection.products_count }} producto{% if collection.products_count != 1 %}s{% endif %} encontrados
      {% else %}
        Productos de demostración — integración con Effi próximamente
      {% endif %}
    </p>
  </div>
  <div class="ph-right">
    <select class="sort-select" onchange="sortProducts(this)">
      <option value="">Más relevantes</option>
      <option value="price-asc">Precio: menor a mayor</option>
      <option value="price-desc">Precio: mayor a menor</option>
      <option value="rating">Mejor valorados</option>
      <option value="newest">Más nuevos</option>
    </select>
    <div class="view-toggle">
      <button class="vtbtn on" onclick="setView('grid', this)" title="Vista cuadrícula">⊞</button>
      <button class="vtbtn" onclick="setView('list', this)" title="Vista lista">☰</button>
    </div>
  </div>
</div>

<!-- LAYOUT PRINCIPAL -->
<div class="cat-layout">

  <!-- ══ SIDEBAR ══ -->
  <aside class="sidebar">

    <!-- Categorías -->
    <div class="sidebar-card reveal">
      <p class="sb-title">Categorías</p>
      <ul class="cat-list">
        <li><a href="javascript:filterCategory('all')" {% unless request.query_string contains 'filter.p.product_type' %}class="active"{% endunless %}>
          🛍 Todos <span class="cnt">{{ collection.products_count }}</span>
        </a></li>
        <li><a href="javascript:filterCategory('Electr%C3%B3nica')" {% if request.query_string contains 'Electr' %}class="active"{% endif %}>
          ⚡ Electrónica
        </a></li>
        <li><a href="javascript:filterCategory('Salud')" {% if request.query_string contains 'Salud' %}class="active"{% endif %}>
          💊 Salud
        </a></li>
        <li><a href="javascript:filterCategory('Belleza')" {% if request.query_string contains 'Belleza' %}class="active"{% endif %}>
          ✨ Belleza
        </a></li>
        <li><a href="javascript:filterCategory('Hogar')" {% if request.query_string contains 'Hogar' %}class="active"{% endif %}>
          🏠 Hogar
        </a></li>
        <li><a href="javascript:filterCategory('Moda')" {% if request.query_string contains 'Moda' %}class="active"{% endif %}>
          👗 Moda
        </a></li>
      </ul>
    </div>

    <!-- Rango de precio -->
    <div class="sidebar-card reveal d1">
      <p class="sb-title">Precio</p>
      <form action="{{ request.path }}" method="get" id="priceFilterForm">
        {%- if request.query_string contains 'sort_by' -%}
          <input type="hidden" name="sort_by" value="{{ request.query_string | split: 'sort_by=' | last | split: '&' | first }}">
        {%- endif -%}
        <div class="price-range">
          <div class="range-inputs">
            <input class="range-inp" type="number" placeholder="$ Mín" id="priceMin"
                   name="filter.v.price.gte" min="0"
                   value="{% if request.query_string contains 'filter.v.price.gte' %}{{ request.query_string | split: 'filter.v.price.gte=' | last | split: '&' | first }}{% endif %}">
            <span class="range-sep">—</span>
            <input class="range-inp" type="number" placeholder="$ Máx" id="priceMax"
                   name="filter.v.price.lte" min="0"
                   value="{% if request.query_string contains 'filter.v.price.lte' %}{{ request.query_string | split: 'filter.v.price.lte=' | last | split: '&' | first }}{% endif %}">
          </div>
          <input class="range-slider" type="range" min="0" max="500" value="500"
                 oninput="document.getElementById('priceMax').value = this.value">
        </div>
      </form>
    </div>

    <!-- Marca (dinámica) -->
    <div class="sidebar-card reveal d2">
      <p class="sb-title">Marca</p>
      <div class="check-list">
        {%- if collection.all_vendors.size > 0 -%}
          {%- for vendor in collection.all_vendors limit: 8 -%}
            <label class="check-item">
              <input type="checkbox"
                     onchange="filterVendor('{{ vendor | escape }}')"
                     {% if request.query_string contains vendor %}checked{% endif %}>
              <span>{{ vendor }}</span>
            </label>
          {%- endfor -%}
        {%- else -%}
          <p style="font-size:.78rem;color:var(--muted);line-height:1.5;">Las marcas aparecerán cuando tengas productos.</p>
        {%- endif -%}
      </div>
    </div>

    <!-- Tipo de producto (dinámico) -->
    <div class="sidebar-card reveal d3">
      <p class="sb-title">Tipo de producto</p>
      <div class="check-list">
        {%- if collection.all_types.size > 0 -%}
          {%- for type in collection.all_types limit: 8 -%}
            {%- if type != blank -%}
              <label class="check-item">
                <input type="checkbox"
                       onchange="filterType('{{ type | escape }}')"
                       {% if request.query_string contains type %}checked{% endif %}>
                <span>{{ type }}</span>
              </label>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          <p style="font-size:.78rem;color:var(--muted);line-height:1.5;">Los tipos aparecen cuando configures el campo "Tipo" en tus productos.</p>
        {%- endif -%}
      </div>
    </div>

    <button class="btn-apply reveal d4" type="submit" form="priceFilterForm">Aplicar filtros</button>
    <button class="btn-clear reveal d4" type="button" onclick="clearFilters()">Limpiar filtros</button>

  </aside>

  <!-- ══ ÁREA DE PRODUCTOS ══ -->
  <main>

    <!-- Banner demo -->
    {% if collection.products_count == 0 %}
      <div style="background:var(--cream); border:1.5px dashed var(--sand); border-radius:16px; padding:12px 18px; margin-bottom:20px; font-size:.82rem; color:var(--muted); display:flex; align-items:center; gap:10px;">
        👋 <span><strong style="color:var(--dark);">Modo demostración</strong> — Estos productos son de ejemplo. Cuando conectes Effi se reemplazarán automáticamente.</span>
      </div>
    {% endif %}

    <!-- Grid de productos -->
    <div class="prods-grid" id="prodGrid">

      {% if collection.products_count > 0 %}
        {% comment %} ── PRODUCTOS REALES DE SHOPIFY ── {% endcomment %}
        {% for product in collection.products %}
          <div class="prod reveal d{{ forloop.index | modulo: 4 | plus: 1 }}" style="position:relative;">
            <a href="{{ product.url }}" style="position:absolute;inset:0;z-index:1;" aria-label="{{ product.title | escape }}"></a>
            <div class="prod-thumb" style="background: linear-gradient(135deg, #f5f0e8, #e8e0d0);">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: 'medium' }}"
                     alt="{{ product.title }}"
                     style="width:100%; height:100%; object-fit:cover; display:block;">
              {% else %}
                <span>📦</span>
              {% endif %}
              {% if product.compare_at_price > product.price %}
                <span class="prod-label lb-hot">Oferta</span>
              {% endif %}
              <button class="prod-wish-btn"
                      data-wish-id="{{ product.id }}"
                      data-wish-title="{{ product.title | escape }}"
                      data-wish-img="{% if product.featured_image %}{{ product.featured_image | img_url: 'medium' }}{% endif %}"
                      data-wish-price="{{ product.price | money }}"
                      data-wish-url="{{ product.url }}"
                      onclick="toggleWish(this)"
                      aria-label="Guardar en favoritos"
                      style="position:relative;z-index:2;">♡</button>
            </div>
            <div class="prod-info">
              <p class="prod-cat">{{ product.type | default: collection.title }}</p>
              <div class="prod-stars"><span class="stars-y">★★★★★</span></div>
              <a href="{{ product.url }}" style="text-decoration:none; color:inherit;">
                <p class="prod-name">{{ product.title }}</p>
              </a>
              <p class="prod-desc" style="display:none; font-size:.78rem; color:var(--muted); line-height:1.5; margin-bottom:10px;">{{ product.description | strip_html | truncate: 100 }}</p>
              <div class="prod-bottom">
                <div class="prod-price-block">
                  {% if product.compare_at_price > product.price %}
                    <span class="prod-price-old">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                  <span class="prod-price-now">{{ product.price | money }}</span>
                </div>
                <form method="post" action="/cart/add" class="ajax-cart-form" style="margin:0;position:relative;z-index:2;">
                  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="prod-cart-btn" {% unless product.available %}disabled{% endunless %}>+</button>
                </form>
              </div>
            </div>
          </div>
        {% endfor %}

      {% else %}
        {% comment %} ── PRODUCTOS DE DEMOSTRACIÓN ── {% endcomment %}

        {% assign demo_products = "🎧|Auriculares Bluetooth Pro Max|Cancelación activa de ruido. Hasta 30h de batería. Compatible iOS y Android.|$129.00|$83.99|−35%|lb-hot|pth-1|⚡ Electrónica,⌚|Smartwatch Fitness Pro Series 5|GPS integrado, monitor de salud 24/7 y resistente al agua.|$119.00||Nuevo|lb-new|pth-2|⚡ Electrónica,📱|Cargador Inalámbrico 15W|Carga rápida Qi. Diseño ultradelgado para todos los dispositivos.|$35.00|$28.00|−20%|lb-off|pth-3|⚡ Electrónica,🖥️|Monitor Curvo 27'' 144Hz|Resolución QHD, panel IPS. Perfecto para gaming y diseño.|$249.00||Nueva|lb-new|pth-4|⚡ Electrónica,🎮|Control Gaming Inalámbrico RGB|Compatible PC/PS/móvil. Vibración háptica y 20h de batería.|$65.00|$55.25|−15%|lb-hot|pth-5|⚡ Electrónica,💊|Pack Vitaminas C + D3 — 60 días|Refuerza tu sistema inmunológico. Sin azúcar, sin gluten.|$34.99||Nuevo|lb-new|pth-2|💊 Salud,🏋️|Proteína Whey Chocolate 2kg|Fórmula avanzada con aminoácidos esenciales. 25g de proteína por dosis.|$69.99||·|lb-new|pth-7|💊 Salud,💄|Sérum Facial Vitamina C 30ml|Ilumina y unifica el tono. Dermatológicamente testado.|$61.00|$52.00|−15%|lb-off|pth-3|✨ Belleza,🧴|Crema Hidratante 24h SPF 50|Protección solar y cuidado intensivo. Para todo tipo de piel.|$44.00|$37.40|−15%|lb-off|pth-6|✨ Belleza,☕|Cafetera Espresso Automática|Presión de 15 bares. Incluye espumador y cápsula de prueba gratis.|$95.00|$76.00|−20%|lb-hot|pth-4|🏠 Hogar,💡|Bombillos LED Smart WiFi Pack x4|16M de colores, compatible con Alexa y Google Home.|$48.00|$36.00|−25%|lb-hot|pth-6|🏠 Hogar,🧹|Robot Aspirador Silencioso|Mapeo inteligente 3D. Control desde app. Autonomía 90min.|$189.00|$149.00|−21%|lb-hot|pth-5|🏠 Hogar" | split: "," %}

        {% for item in demo_products %}
          {% assign parts = item | split: "|" %}
          {% if parts.size >= 9 %}
          <div class="prod reveal">
            <div class="prod-thumb {{ parts[7] }}">
              <span style="font-size:3.5rem;">{{ parts[0] }}</span>
              {% if parts[5] != '' and parts[5] != '·' %}
                <span class="prod-label {{ parts[6] }}">{{ parts[5] }}</span>
              {% endif %}
              <button class="prod-wish-btn"
                      data-wish-id="demo-{{ forloop.index }}"
                      data-wish-title="{{ parts[1] }}"
                      data-wish-img=""
                      data-wish-price="{{ parts[3] }}"
                      onclick="toggleWish(this)"
                      aria-label="Guardar">♡</button>
            </div>
            <div class="prod-info">
              <p class="prod-cat" style="color:var(--red);">{{ parts[8] }}</p>
              <div class="prod-stars"><span class="stars-y">★★★★★</span></div>
              <p class="prod-name">{{ parts[1] }}</p>
              <p class="prod-desc" style="display:none; font-size:.78rem; color:var(--muted); line-height:1.5; margin-bottom:10px;">{{ parts[2] }}</p>
              <div class="prod-bottom">
                <div class="prod-price-block">
                  {% if parts[4] != '' %}
                    <span class="prod-price-old">{{ parts[3] }}</span>
                    <span class="prod-price-now">{{ parts[4] }}</span>
                  {% else %}
                    <span class="prod-price-now">{{ parts[3] }}</span>
                  {% endif %}
                </div>
                <button class="prod-cart-btn" onclick="showToast('🛒 Producto de demo — próximamente disponible')">+</button>
              </div>
            </div>
          </div>
          {% endif %}
        {% endfor %}

      {% endif %}

    </div><!-- /prodGrid -->

    <!-- Paginación (solo con productos reales) -->
    {% if collection.products_count > 0 and paginate.pages > 1 %}
      <div class="pagination reveal">
        {% if paginate.previous %}
          <a href="{{ paginate.previous.url }}" class="pg-btn arrow">‹</a>
        {% else %}
          <button class="pg-btn arrow" disabled>‹</button>
        {% endif %}
        {% for part in paginate.parts %}
          {% if part.is_link %}
            <a href="{{ part.url }}" class="pg-btn">{{ part.title }}</a>
          {% else %}
            {% if part.title == '…' %}
              <span class="pg-dots">…</span>
            {% else %}
              <span class="pg-btn on">{{ part.title }}</span>
            {% endif %}
          {% endif %}
        {% endfor %}
        {% if paginate.next %}
          <a href="{{ paginate.next.url }}" class="pg-btn arrow">›</a>
        {% else %}
          <button class="pg-btn arrow" disabled>›</button>
        {% endif %}
      </div>
    {% elsif collection.products_count == 0 %}
      <!-- Paginación demo -->
      <div class="pagination reveal">
        <button class="pg-btn arrow">‹</button>
        <button class="pg-btn on">1</button>
        <button class="pg-btn" onclick="showToast('Más productos con la integración de Effi')">2</button>
        <button class="pg-btn" onclick="showToast('Más productos con la integración de Effi')">3</button>
        <span class="pg-dots">...</span>
        <button class="pg-btn" onclick="showToast('Más productos con la integración de Effi')">12</button>
        <button class="pg-btn arrow">›</button>
      </div>
    {% endif %}

  </main>
</div><!-- /cat-layout -->

<script>
// ── GRID / LIST VIEW ─────────────────────────────
function setView(type, btn) {
  document.querySelectorAll('.vtbtn').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  const grid = document.getElementById('prodGrid');
  if (type === 'list') {
    grid.classList.add('list-view');
    grid.querySelectorAll('.prod-desc').forEach(d => d.style.display = 'block');
    grid.querySelectorAll('.prod-cart-btn').forEach(b => { b.textContent = '🛒 Agregar'; });
  } else {
    grid.classList.remove('list-view');
    grid.querySelectorAll('.prod-desc').forEach(d => d.style.display = 'none');
    grid.querySelectorAll('.prod-cart-btn').forEach(b => { b.textContent = '+'; });
  }
}

// ── SORT ─────────────────────────────────────────
function sortProducts(select) {
  const val = select.value;
  const sortMap = {
    'price-asc':  'price-ascending',
    'price-desc': 'price-descending',
    'newest':     'created-descending',
    'rating':     'best-selling',
    '':           'manual'
  };
  const url = new URL(window.location.href);
  if (val === '') {
    url.searchParams.delete('sort_by');
  } else {
    url.searchParams.set('sort_by', sortMap[val]);
  }
  window.location.href = url.toString();
}

// ── FILTER BY VENDOR ─────────────────────────────
function filterVendor(vendor) {
  const url = new URL(window.location.href);
  const current = url.searchParams.getAll('filter.p.vendor');
  url.searchParams.delete('filter.p.vendor');
  if (current.includes(vendor)) {
    current.filter(v => v !== vendor).forEach(v => url.searchParams.append('filter.p.vendor', v));
  } else {
    [...current, vendor].forEach(v => url.searchParams.append('filter.p.vendor', v));
  }
  window.location.href = url.toString();
}

// ── FILTER BY PRODUCT TYPE ────────────────────────
function filterType(type) {
  const url = new URL(window.location.href);
  const current = url.searchParams.getAll('filter.p.product_type');
  url.searchParams.delete('filter.p.product_type');
  if (current.includes(type)) {
    current.filter(t => t !== type).forEach(t => url.searchParams.append('filter.p.product_type', t));
  } else {
    [...current, type].forEach(t => url.searchParams.append('filter.p.product_type', t));
  }
  window.location.href = url.toString();
}

// ── CLEAR FILTERS ─────────────────────────────────
function clearFilters() {
  window.location.href = '{{ request.path }}';
}

// ── FILTER BY CATEGORY (product_type) ────────────────
function filterCategory(type) {
  const url = new URL(window.location.href);
  if (type === 'all') {
    url.searchParams.delete('filter.p.product_type');
  } else {
    url.searchParams.set('filter.p.product_type', decodeURIComponent(type));
  }
  window.location.href = url.toString();
}

// ── TOAST ────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  if (!t) return;
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}
</script>

{% endpaginate %}

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Productos por página",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ]
}
{% endschema %}
