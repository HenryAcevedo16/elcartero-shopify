<style>
  /* ── Reset del footer global de cartero-base.css ── */
  footer.fc-wrap {
    padding: 0 !important;
    background: transparent !important;
  }

  /* ── El CSS global pone position:fixed height:80px en TODOS los nav.
     Reseteamos los nav internos del footer ── */
  nav.fc-pills,
  nav.fc-legal {
    position: static !important;
    height: auto !important;
    background: transparent !important;
    border-bottom: none !important;
    padding: 0 !important;
    top: auto !important;
    left: auto !important;
    right: auto !important;
    z-index: auto !important;
    display: flex !important;
    backdrop-filter: none !important;
    transition: none !important;
  }

  /* ── Footer ElCarteroRD — igual ancho y estilo flotante que el hero ── */
  .fc-wrap {
    position: relative;
    width: auto;
    min-height: 800px;
    font-family: 'Poppins', sans-serif;
    color: #fff;
    overflow: hidden;
    /* Margen superior para separarlo del contenido, margen inferior de 20px */
    margin: 100px 48px 20px;
    border-radius: 50px;
  }
  .fc-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .fc-bg svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .fc-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 0 7% 32px;
    padding-top: clamp(56px, 27vh, 280px);
    box-sizing: border-box;
    min-height: 480px;
  }
  .fc-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .fc-left {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .fc-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 14px;
  }
  .fc-tagline {
    margin: 0;
    font-size: clamp(13px, 1.4vw, 18px);
    font-weight: 400;
    letter-spacing: -0.03em;
  }
  .fc-desc {
    margin: 0;
    font-size: clamp(12px, 1.2vw, 16px);
    color: #cfcfcf;
    line-height: 1.55;
    text-align: right;
    max-width: 320px;
    letter-spacing: -0.02em;
  }
  .fc-pills {
    display: flex;
    gap: 0px;
    flex-wrap: wrap;
  }
  .fc-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: clamp(8px, 1vw, 12px) clamp(16px, 2vw, 26px);
    border-radius: 999px;
    font-family: 'Poppins', sans-serif;
    font-size: clamp(11px, 1vw, 15px);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: #fff;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid #919191;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    white-space: nowrap;
    transition: background 0.2s, transform 0.18s;
  }
  .fc-pill:hover {
    background: rgba(255, 255, 255, 0.28);
    color: #fff;
    transform: translateY(-2px);
  }
  .fc-socials {
    display: flex;
    gap: 10px;
  }
  .fc-social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(36px, 3.5vw, 50px);
    height: clamp(36px, 3.5vw, 50px);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.22);
    text-decoration: none;
    transition: background 0.2s, transform 0.18s;
  }
  .fc-social:hover {
    background: rgba(255, 255, 255, 0.28);
    transform: translateY(-2px);
  }
  .fc-social svg {
    display: block;
  }
  .fc-logo-row {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 60px 0;
  }
  .fc-logo {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }
  .fc-hr {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin: 0;
  }
  .fc-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 50px;
    margin-bottom: 40px;
  }
  .fc-copy {
    font-size: clamp(10px, 0.85vw, 13px);
    color: #cfcfcf;
    margin: 0;
    font-weight: 500;
  }
  .fc-legal {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  .fc-legal a {
    font-size: clamp(10px, 0.85vw, 13px);
    color: #cfcfcf;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }
  .fc-legal a:hover {
    color: #fff;
  }

  @media (max-width: 960px) {
    .fc-wrap {
      margin: 80px 24px 20px;
    }
    .fc-inner {
      padding-top: 240px;
      padding-left: 24px;
      padding-right: 24px;
    }
    .fc-top {
      gap: 16px;
    }
    .fc-desc {
      max-width: 260px;
      font-size: 12px;
    }
    .fc-pill {
      padding: 8px 14px;
      font-size: 11px;
    }
    .fc-social {
      width: 36px;
      height: 36px;
    }
  }

  @media (max-width: 768px) {
    .fc-wrap {
      margin: 60px 16px 20px;
      min-height: auto;
    }
    .fc-inner {
      padding-top: 110px;
      padding-bottom: 30px;
      padding-left: 24px;
      padding-right: 24px;
    }
    .fc-logo-row {
      padding: 30px 0;
    }
    .fc-logo {
      width: 90%;
      max-width: 320px;
      margin: 0 auto;
    }
    .fc-top {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 24px;
    }
    .fc-left,
    .fc-right {
      align-items: center;
      text-align: center;
    }
    .fc-desc {
      text-align: center;
      max-width: 100%;
    }
    .fc-pills {
      justify-content: center;
    }
    .fc-socials {
      justify-content: center;
    }
    .fc-bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 16px;
    }
    .fc-legal {
      justify-content: center;
      gap: 16px;
    }
  }
</style>

