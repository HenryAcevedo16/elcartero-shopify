      </svg>
    </div>

    <!-- Fila inferior: copyright + links legales -->
    <div class="footer-bottom">
      <p class="footer-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos los derechos reservados.</p>
      <div class="footer-legal">
        <a href="/pages/politica-de-privacidad">Política y Privacidad</a>
        <a href="/pages/devoluciones">Devoluciones</a>
      </div>
    </div>

  </div>
</footer>

<style>
.elcartero-footer {
  background-color: #0d1224;
  border-radius: 60px 60px 0 0;
  color: #fff;
  font-family: 'Poppins', sans-serif;
  padding: 60px 80px 40px;
  margin-top: 40px;
  overflow: hidden;
}

.footer-inner {
  max-width: 1800px;
  margin: 0 auto;
}

.footer-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32px;
}

.footer-tagline {
  font-size: 22px;
  font-weight: 400;
  letter-spacing: -0.44px;
  margin: 0;
  max-width: 480px;
}

.footer-description {
  font-size: 22px;
  font-weight: 400;
  letter-spacing: -0.44px;
  text-align: right;
  margin: 0;
  max-width: 420px;
}

.footer-mid {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40px;
}

.footer-nav {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.footer-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16px 36px;
  border-radius: 50px;
  border: 1px solid #919191;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(6px);
  color: #fff;
  font-size: 20px;
  font-weight: 400;
  letter-spacing: -0.4px;
  text-decoration: none;
  transition: background 0.2s;
}

.footer-btn:hover {
  background: rgba(255, 255, 255, 0.28);
  color: #fff;
}

.footer-social {
  display: flex;
  gap: 10px;
}

.footer-social-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54px;
  height: 54px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255,255,255,0.2);
  text-decoration: none;
  transition: background 0.2s;
}

.footer-social-icon:hover {
  background: rgba(255, 255, 255, 0.28);
}

.footer-logo-wrap {
  text-align: center;
  padding: 20px 0 30px;
}

.footer-logo-svg {
  max-width: 100%;
  height: auto;
  display: block;
  margin: 0 auto;
}

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 24px;
  flex-wrap: wrap;
  gap: 12px;
}

.footer-copy {
  font-size: 18px;
  color: #cfcfcf;
  margin: 0;
  letter-spacing: -0.36px;
}

.footer-legal {
  display: flex;
  gap: 32px;
}

.footer-legal a {
  font-size: 18px;
  color: #cfcfcf;
  text-decoration: none;
  letter-spacing: -0.36px;
}

.footer-legal a:hover {
  color: #fff;
}

@media (max-width: 768px) {
  .elcartero-footer {
    padding: 40px 24px 32px;
    border-radius: 40px 40px 0 0;
  }

  .footer-top,
  .footer-mid,
  .footer-bottom {
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .footer-description {
    text-align: left;
  }

  .footer-legal {
    gap: 20px;
  }

  .footer-social {
    align-self: flex-end;
  }
}
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "store_description",
      "label": "Store Description",
      "default": "Electrónica, salud, belleza, hogar y más con precios increíbles y envío rápido."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
