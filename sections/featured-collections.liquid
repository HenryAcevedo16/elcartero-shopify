<section class="wrap">
  <div class="row-header reveal">
    <div>
      <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>
    {% if section.settings.btn_link != blank %}
      <a href="{{ section.settings.btn_link }}" class="view-all">{{ section.settings.btn_text }} &rarr;</a>
    {% endif %}
  </div>

  <div class="cats-grid">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {% assign filter_val = block.settings.filter_value | default: block.settings.name | url_encode %}
        {% assign cat_url = '/collections/all?filter.p.product_type=' | append: filter_val %}
        <a href="{{ cat_url }}"
           class="cat-card reveal"
           style="text-decoration:none;color:inherit;--cat-bg:{{ block.settings.color_bg }};--cat-accent:{{ block.settings.color_accent }};--cat-glow:{{ block.settings.color_glow }};"
           {{ block.shopify_attributes }}>
          <div class="cat-glow" style="background:radial-gradient(circle at 30% 30%,var(--cat-glow,rgba(34,194,68,0.25)),transparent 70%);"></div>
          <span class="cat-chip" style="background:var(--cat-accent,#22c244);color:#fff;">
            {% assign col = collections[block.settings.collection] %}
            {% if col != blank %}{{ col.all_products_count }}+{% else %}0+{% endif %}
          </span>
        <div class="cat-emoji-wrap">{{ block.settings.emoji | default: '✨' }}</div>
          <p class="cat-card-name">{{ block.settings.name | default: 'Categoría' }}</p>
          <p class="cat-card-count">{{ block.settings.subtitle }}</p>
          <div class="cat-arrow" style="color:var(--cat-accent,#22c244);">→</div>
        </a>
      {% endfor %}
    {% else %}
      <!-- Fallback: 4 categorías estáticas -->
      <a href="/collections/all?filter.p.product_type=Electr%C3%B3nica" class="cat-card reveal" style="text-decoration:none;color:inherit;--cat-bg:#f0f4ff;--cat-accent:#3b5bdb;--cat-glow:#bac8ff;">
        <div class="cat-glow" style="background:radial-gradient(circle at 30% 30%,#bac8ff,transparent 70%);"></div>
        <span class="cat-chip" style="background:#3b5bdb;color:#fff;">Ver</span>
        <div class="cat-emoji-wrap">⚡</div>
        <p class="cat-card-name">Electrónica</p>
        <p class="cat-card-count">Gadgets, cámaras y accesorios</p>
        <div class="cat-arrow" style="color:#3b5bdb;">→</div>
      </a>
      <a href="/collections/all?filter.p.product_type=Belleza" class="cat-card reveal" style="text-decoration:none;color:inherit;--cat-bg:#fff0f6;--cat-accent:#e91e8c;--cat-glow:#fbb6d8;">
        <div class="cat-glow" style="background:radial-gradient(circle at 30% 30%,#fbb6d8,transparent 70%);"></div>
        <span class="cat-chip" style="background:#e91e8c;color:#fff;">Ver</span>
        <div class="cat-emoji-wrap">💄</div>
        <p class="cat-card-name">Belleza</p>
        <p class="cat-card-count">Skincare, maquillaje y cuidado personal</p>
        <div class="cat-arrow" style="color:#e91e8c;">→</div>
      </a>
      <a href="/collections/all?filter.p.product_type=Salud" class="cat-card reveal" style="text-decoration:none;color:inherit;--cat-bg:#f0faf3;--cat-accent:#22c244;--cat-glow:#b7f5c8;">
        <div class="cat-glow" style="background:radial-gradient(circle at 30% 30%,#b7f5c8,transparent 70%);"></div>
        <span class="cat-chip" style="background:#22c244;color:#fff;">Ver</span>
        <div class="cat-emoji-wrap">💊</div>
        <p class="cat-card-name">Salud</p>
        <p class="cat-card-count">Vitaminas, suplementos y más</p>
        <div class="cat-arrow" style="color:#22c244;">→</div>
      </a>
      <a href="/collections/all?filter.p.product_type=Hogar" class="cat-card reveal" style="text-decoration:none;color:inherit;--cat-bg:#fff8e1;--cat-accent:#f5a623;--cat-glow:#ffe082;">
        <div class="cat-glow" style="background:radial-gradient(circle at 30% 30%,#ffe082,transparent 70%);"></div>
        <span class="cat-chip" style="background:#f5a623;color:#fff;">Ver</span>
        <div class="cat-emoji-wrap">🏠</div>
        <p class="cat-card-name">Hogar</p>
        <p class="cat-card-count">Organización, cocina y decoración</p>
        <div class="cat-arrow" style="color:#f5a623;">→</div>
      </a>
      <a href="/collections/all?filter.p.product_type=Viajes%20y%20equipaje" class="cat-card reveal" style="text-decoration:none;color:inherit;--cat-bg:#e0f7fa;--cat-accent:#00acc1;--cat-glow:#b2ebf2;">
        <div class="cat-glow" style="background:radial-gradient(circle at 30% 30%,#b2ebf2,transparent 70%);"></div>
        <span class="cat-chip" style="background:#00acc1;color:#fff;">Ver</span>
        <div class="cat-emoji-wrap">🧳</div>
        <p class="cat-card-name">Viajes</p>
        <p class="cat-card-count">Maletas, estuches y accesorios</p>
        <div class="cat-arrow" style="color:#00acc1;">→</div>
      </a>
    {% endif %}
  </div>

</section>

<style>
  .cats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-top: 32px;
  }

  .cat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    position: relative;
    background: var(--cat-bg, #f5f8f0);
    border-radius: 28px;
    padding: 32px 20px 24px;
    text-align: center;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.04);
    transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s;
    cursor: pointer;
  }

  .cat-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.08);
  }

  .cat-card .cat-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.85;
  }

  .cat-card > * { position: relative; z-index: 1; }

  .cat-chip {
    position: absolute;
    top: 18px;
    right: 18px;
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .cat-emoji-wrap {
    font-size: 4rem;
    line-height: 1;
    margin: 10px 0 20px;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  
  .cat-card:hover .cat-emoji-wrap {
    transform: scale(1.15) rotate(5deg);
  }

  .cat-card-name {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--dark, #1a2e1e);
    margin: 0 0 6px;
    letter-spacing: -0.02em;
  }

  .cat-card-count {
    font-size: 0.85rem;
    color: var(--muted, #6b8f72);
    margin: 0 0 16px;
    line-height: 1.4;
  }

  .cat-arrow {
    margin-top: auto;
    font-size: 1.3rem;
    font-weight: 800;
    transition: transform 0.3s;
  }

  .cat-card:hover .cat-arrow {
    transform: translateX(6px);
  }

  @media (max-width: 640px) {
    .cats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Categorías Destacadas",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño arriba",
      "default": "Explorar por categoría"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "¿Qué buscas hoy?"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Texto del botón",
      "default": "Ver todas"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Enlace del botón"
    }
  ],
  "blocks": [
    {
      "type": "categoria",
      "name": "Categoría",
      "limit": 6,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Colección de Shopify"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre (si no hay colección)",
          "default": "Categoría"
        },
        {
          "type": "url",
          "id": "fallback_url",
          "label": "Enlace (si no hay colección)"
        },
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji",
          "default": "✨"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo",
          "default": "Ver productos"
        },
        {
          "type": "text",
          "id": "filter_value",
          "label": "Valor del filtro (product_type)",
          "info": "El tipo de producto exacto configurado en Shopify. Ej: Electrónica"
        },
        {
          "type": "color",
          "id": "color_bg",
          "label": "Color de fondo",
          "default": "#f0faf3"
        },
        {
          "type": "color",
          "id": "color_accent",
          "label": "Color del badge",
          "default": "#22c244"
        },
        {
          "type": "color",
          "id": "color_glow",
          "label": "Color del resplandor",
          "default": "#b7f5c8"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categorías Destacadas",
      "blocks": [
        {
          "type": "categoria",
          "settings": {
            "name": "Electrónica",
            "filter_value": "Electrónica",
            "emoji": "⚡",
            "subtitle": "Gadgets, cámaras y accesorios",
            "color_bg": "#f0f4ff",
            "color_accent": "#3b5bdb",
            "color_glow": "#bac8ff"
          }
        },
        {
          "type": "categoria",
          "settings": {
            "name": "Belleza",
            "filter_value": "Belleza",
            "emoji": "💄",
            "subtitle": "Skincare, maquillaje y cuidado personal",
            "color_bg": "#fff0f6",
            "color_accent": "#e91e8c",
            "color_glow": "#fbb6d8"
          }
        },
        {
          "type": "categoria",
          "settings": {
            "name": "Salud",
            "filter_value": "Salud",
            "emoji": "💊",
            "subtitle": "Vitaminas, suplementos y más",
            "color_bg": "#f0faf3",
            "color_accent": "#22c244",
            "color_glow": "#b7f5c8"
          }
        },
        {
          "type": "categoria",
          "settings": {
            "name": "Hogar",
            "filter_value": "Hogar",
            "emoji": "🏠",
            "subtitle": "Organización, cocina y decoración",
            "color_bg": "#fff8e1",
            "color_accent": "#f5a623",
            "color_glow": "#ffe082"
          }
        },
        {
          "type": "categoria",
          "settings": {
            "name": "Viajes",
