  var provinciaSeleccionada = 'Distrito Nacional';

  function onProvinceSelect(value) {
    provinciaSeleccionada = value;
    // Reset municipio
    document.getElementById('fMunicipio').value = '';
    document.getElementById('munLabel').textContent = 'Selecciona un municipio';
    document.getElementById('fMunicipioBtn').classList.add('is-placeholder');
    // Cerrar ambos dropdowns
    document.getElementById('provDropdown').classList.remove('open');
    document.getElementById('munDropdown').classList.remove('open');
    document.getElementById('fProvinciaBtn').classList.remove('open');
    document.getElementById('fMunicipioBtn').classList.remove('open');
  }

  function renderProvList(filter) {
    var list = document.getElementById('provList');
    if (!list) return;
    var q = (filter || '').toLowerCase().trim();
    var current = (document.getElementById('fProvincia') || {}).value || '';
    var filtered = q ? PROVINCIAS.filter(function(p){ return p.toLowerCase().indexOf(q) !== -1; }) : PROVINCIAS;
    if (filtered.length === 0) {
      list.innerHTML = '<div class="prov-empty">Sin resultados</div>';
      return;
    }
    list.innerHTML = '';
    filtered.forEach(function(p) {
      var div = document.createElement('div');
      div.className = 'prov-item' + (p === current ? ' selected' : '');
      div.setAttribute('data-value', p);
      div.textContent = p;
      list.appendChild(div);
    });
  }

  function toggleProv() {
    var btn = document.getElementById('fProvinciaBtn');
    var dd  = document.getElementById('provDropdown');
    var search = document.getElementById('provSearch');
    if (!btn || !dd) return;
    var isOpen = dd.classList.contains('open');
    if (isOpen) {
      dd.classList.remove('open');
      btn.classList.remove('open');
    } else {
      dd.classList.add('open');
      btn.classList.add('open');
      renderProvList('');
      if (search) { search.value = ''; setTimeout(function(){ search.focus(); }, 60); }
    }
  }

  function filterProv(val) { renderProvList(val); }

  // Delegación de eventos — click en items y cierre al click afuera
  document.addEventListener('click', function(e) {
    // ── Delegación para Municipio (primero para evitar que `.prov-item` lo capture) ──
    var itemMun = e.target.closest ? e.target.closest('.prov-item') : null;
    if (itemMun && itemMun.hasAttribute('data-value') && itemMun.closest('#munDropdown')) {
      var valueMun = itemMun.getAttribute('data-value');
      var hiddenInputMun = document.getElementById('fMunicipio');
      var labelMun  = document.getElementById('munLabel');
      var btnMun    = document.getElementById('fMunicipioBtn');
      var ddMun     = document.getElementById('munDropdown');
      if (hiddenInputMun) hiddenInputMun.value = valueMun;
      if (labelMun) labelMun.textContent = valueMun;
      if (btnMun) btnMun.classList.remove('is-placeholder', 'input-error', 'open');
      if (ddMun)  ddMun.classList.remove('open');
      renderMunList('');
      return;
    }

    // ── Delegación para Provincia ──
    var item = e.target.closest ? e.target.closest('.prov-item') : null;
    if (item && item.hasAttribute('data-value') && !item.closest('#munDropdown')) {
      var value = item.getAttribute('data-value');
      var hiddenInput = document.getElementById('fProvincia');
      var label  = document.getElementById('provLabel');
      var btn    = document.getElementById('fProvinciaBtn');
      var dd     = document.getElementById('provDropdown');
      if (hiddenInput) hiddenInput.value = value;
      if (label) label.textContent = value;
      if (btn) btn.classList.remove('is-placeholder', 'input-error', 'open');
      if (dd)  dd.classList.remove('open');
      // Llamar onProvinceSelect para cargar municipios
      onProvinceSelect(value);
      renderProvList('');
      return;
    }

    // Cerrar provincia dropdown al click afuera
    var wrap = document.getElementById('provinciaWrap');
    if (wrap && !wrap.contains(e.target)) {
      var dd2  = document.getElementById('provDropdown');
      var btn2 = document.getElementById('fProvinciaBtn');
      if (dd2)  dd2.classList.remove('open');
      if (btn2) btn2.classList.remove('open');
    }

    // Cerrar municipio dropdown al click afuera
    var wrapMun = document.getElementById('municipioWrap');
    if (wrapMun && !wrapMun.contains(e.target)) {
      var dd2Mun  = document.getElementById('munDropdown');
      var btn2Mun = document.getElementById('fMunicipioBtn');
      if (dd2Mun)  dd2Mun.classList.remove('open');
      if (btn2Mun) btn2Mun.classList.remove('open');
    }
  });

  /* ── CUSTOM MUNICIPIO DROPDOWN ── */
  var MUNICIPIOS = [];

  function renderMunList(filter) {
    var list = document.getElementById('munList');
    if (!list) return;

    var q = (filter || '').toLowerCase().trim();
    var current = document.getElementById('fMunicipio').value || '';
    var municipiosDisponibles = MUNICIPIOS_POR_PROVINCIA[provinciaSeleccionada] || [];

    var filtered = q ? municipiosDisponibles.filter(function(m){
      return m.toLowerCase().indexOf(q) !== -1;
    }) : municipiosDisponibles;

    if (filtered.length === 0) {
      list.innerHTML = '<div class="prov-empty">' + (q ? 'Sin resultados' : 'Selecciona una provincia primero') + '</div>';
      return;
    }

    list.innerHTML = '';
    filtered.forEach(function(m) {
      var div = document.createElement('div');
      div.className = 'prov-item mun-item' + (m === current ? ' selected' : '');
      div.setAttribute('data-value', m);
      div.textContent = m;
      list.appendChild(div);
    });
  }

  function toggleMun() {
    var btn = document.getElementById('fMunicipioBtn');
    var dd  = document.getElementById('munDropdown');
    var search = document.getElementById('munSearch');
    if (!btn || !dd) return;
    var isOpen = dd.classList.contains('open');
    if (isOpen) {
      dd.classList.remove('open');
      btn.classList.remove('open');
    } else {
      dd.classList.add('open');
      btn.classList.add('open');
      renderMunList('');
      if (search) { search.value = ''; setTimeout(function(){ search.focus(); }, 60); }
    }
  }

  function filterMun(val) { renderMunList(val); }

  // ── Redirección Directa a Paso 2 (Desde Comprar Ahora) ──
  (function() {
    if (sessionStorage.getItem('cart_step')) {
      var strStep = sessionStorage.getItem('cart_step');
      var s = parseInt(strStep, 10);
      sessionStorage.removeItem('cart_step');
      if (s && s >= 1 && s <= 3) {
        // Remover animación para el salto inicial si la hay,
        // esto asegura que entre directo sin flash.
        var s1 = document.getElementById('step-1');
        var s2 = document.getElementById('step-2');
        if (s1 && s2) {
           s1.style.transition = 'none';
           s2.style.transition = 'none';
           goToStep(s);
           setTimeout(function() {
             s1.style.transition = '';
             s2.style.transition = '';
           }, 50);
        }
      }
    }
  })();
</script>

