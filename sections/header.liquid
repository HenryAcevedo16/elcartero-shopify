<nav>
  <a href="{{ routes.root_url }}" class="nav-brand" style="display:flex; align-items:center; gap:8px;">
    {%- if settings.logo != blank -%}
      <img src="{{ settings.logo | image_url: width: settings.logo_max_width }}" 
           alt="{{ shop.name }}" 
           style="width: {{ settings.logo_max_width }}px; height: auto;">
    {%- else -%}
      <svg width="34" height="38" viewBox="0 0 40 46" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M20 46C20 46 40 30 40 20C40 9 31 0 20 0C9 0 0 9 0 20C0 30 20 46 20 46Z" fill="url(#paint0_linear_logo)"/>
        <circle cx="20" cy="18" r="9" fill="white"/>
        <path d="M26 18H33C33 23 28 28 20 28V18H26Z" fill="#ff1921"/>
        <defs>
          <linearGradient id="paint0_linear_logo" x1="0" y1="0" x2="40" y2="40" gradientUnits="userSpaceOnUse">
            <stop stop-color="#8a0003"/>
            <stop offset="1" stop-color="#DC2626"/>
          </linearGradient>
        </defs>
      </svg>
      <div class="nav-brand-name" style="font-size:1.4rem; letter-spacing:-0.03em; font-weight:800; color:#222;">
        El<span style="color:#DC2626;">Cartero</span><sub style="font-size:0.5em; color:#000;">RD</sub>
      </div>
    {%- endif -%}
  </a>
  <ul class="nav-menu" style="gap:48px;">
    {% for link in linklists.main-menu.links %}
      <li><a href="{{ link.url }}" style="text-transform:none; font-weight:400; color:#0F172A;" {% if link.active %}class="active"{% endif %}>{{ link.title }}</a></li>
    {% endfor %}
  </ul>
  <div class="nav-right">
    <form action="{{ routes.search_url }}" class="nav-search-box" method="get" role="search" style="background:#fff; padding:6px 16px;">
      <input type="hidden" name="type" value="product">
      <input type="text" name="q" placeholder="Buscar producto" value="{{ search.terms | escape }}" style="width:130px; font-weight:400;">
    </form>
    <button onclick="wlTogglePanel()" class="icon-btn" aria-label="Mis favoritos" style="border:1px solid #1E293B;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-top:2px;">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
      <span class="badge wish-badge" style="display:none;background:#DC2626;">0</span>
    </button>
    <a href="/cart" class="icon-btn" aria-label="Carrito de compras" style="border:1px solid #1E293B;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-top:1px;">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <path d="M16 10a4 4 0 0 1-8 0"></path>
      </svg>
      {% if cart.item_count > 0 %}
        <span class="badge" id="cartBadge" style="background:#DC2626;">{{ cart.item_count }}</span>
      {% endif %}
    </a>
    <!-- Botón hamburguesa (visible solo en móvil) -->
    <button class="hamburger" id="hamburgerBtn" aria-label="Abrir menú" aria-expanded="false"
            onclick="toggleMobileNav()">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<!-- Overlay de navegación móvil -->
<div class="mobile-nav" id="mobileNav" role="dialog" aria-label="Menú de navegación">
  <button class="mobile-nav-close" aria-label="Cerrar menú" onclick="toggleMobileNav()">×</button>
  {% for link in linklists.main-menu.links %}
    <a href="{{ link.url }}" {% if link.active %}class="active"{% endif %}>{{ link.title }}</a>
  {% endfor %}
  <a href="/cart" class="mobile-nav-red">🛒 Carrito
    {% if cart.item_count > 0 %}({{ cart.item_count }}){% endif %}
  </a>
</div>

<script>
  // Navbar scroll effect
  window.addEventListener('scroll', function() {
    const nav = document.querySelector('nav');
    if (window.scrollY > 10) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  });

  function toggleMobileNav() {
    const btn = document.getElementById('hamburgerBtn');
    const nav = document.getElementById('mobileNav');
    const isOpen = nav.classList.contains('open');
    btn.classList.toggle('open');
    nav.classList.toggle('open');
    btn.setAttribute('aria-expanded', !isOpen);
    document.body.style.overflow = isOpen ? '' : 'hidden';
  }
  // Cerrar al hacer clic en un link del menú
  document.getElementById('mobileNav').querySelectorAll('a').forEach(function(link) {
    link.addEventListener('click', function() {
      if (document.getElementById('mobileNav').classList.contains('open')) {
        toggleMobileNav();
      }
    });
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
